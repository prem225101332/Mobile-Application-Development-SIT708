<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvQuestionCounter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Question 1 of 10"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"/>

        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="14sp"
            android:textColor="@color/color_primary"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnThemeToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="18sp"
            android:backgroundTint="@color/color_divider"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:progress="10"
        app:trackCornerRadius="4dp"
        app:indicatorColor="@color/color_primary"
        app:trackColor="@color/color_progress_track"/>

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Question goes here?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:padding="24dp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption0"
            style="@style/Widget.QuizzApp.Button.Option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Option A"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption1"
            style="@style/Widget.QuizzApp.Button.Option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Option B"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption2"
            style="@style/Widget.QuizzApp.Button.Option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Option C"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption3"
            style="@style/Widget.QuizzApp.Button.Option"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Option D"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        style="@style/Widget.QuizzApp.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/btn_submit"/>

</LinearLayout>