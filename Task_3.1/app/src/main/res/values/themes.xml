<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.QuizzApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/color_accent</item>
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_text_primary</item>
        <item name="android:statusBarColor">@color/color_topbar_bg</item>
    </style>

    <style name="Widget.QuizzApp.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">56dp</item>
        <item name="backgroundTint">@color/color_primary</item>
        <item name="cornerRadius">28dp</item>
    </style>

    <style name="Widget.QuizzApp.Button.Option" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/color_option_text</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:paddingStart">20dp</item>
        <item name="strokeColor">@color/color_option_border</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/color_option_bg</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>