<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.sportsfeedapp.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/action_home_to_bookmarks"
            app:destination="@id/bookmarksFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.sportsfeedapp.DetailFragment"
        android:label="Detail">
        <argument
            android:name="newsId"
            app:argType="integer"
            android:defaultValue="-1" />
        <action
            android:id="@+id/action_detail_to_detail"
            app:destination="@id/detailFragment"
            app:popUpTo="@id/detailFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/bookmarksFragment"
        android:name="com.example.sportsfeedapp.BookmarksFragment"
        android:label="Bookmarks">
        <action
            android:id="@+id/action_bookmarks_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

</navigation>